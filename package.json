{
  "name": "eduplay",
  "version": "0.1.7",
  "description": "EduPlay - A Smart Educational Media Player for Students. Watch lectures, auto-generate captions, search transcripts, and ask questions directly from videos.",
  "author": {
    "name": "Drona Srivastava",
    "email": "srivastavadrona@gmail.com",
    "github": "https://github.com/Drona-Srivastava"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder -p always",
    "postinstall": "node copyFFmpeg.js",
    "release": "npm version patch && git push origin main --follow-tags",
    "dist": "electron-builder",
    "dist:all": "npm run dist:win && npm run dist:linux && npm run dist:mac",
    "dist:win": "electron-builder --win --x64 -c.directories.output=dist/win",
    "dist:linux": "electron-builder --linux --x64 -c.directories.output=dist/linux",
    "dist:mac": "electron-builder --mac --x64 -c.directories.output=dist/mac"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Drona-Srivastava/EduPlay.git"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron-log": "^5.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "music-metadata": "^7.14.0",
    "srt-to-vtt": "^1.1.3"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.eduplay.mediaplayer",
    "productName": "EduPlay",
    "asar": true,
    "asarUnpack": [
      "**/*.py"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "menu-template.js",
      "release-notes.js",
      "styles.css",
      "subtitles.js",
      "constants.js",
      "fileSystem.js",
      "fullscreenManager.js",
      "hardwareAccelerations.js",
      "mediaControl.js",
      "playbackPosition.js",
      "playerUI.js",
      "themes.js",
      "utils.js"
    ],
    "extraResources": [
      {
        "from": "python_dist/",
        "to": "python_dist/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "meta/",
        "to": "meta/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ffmpeg-binaries/",
        "to": "ffmpeg-binaries/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "meta/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "meta/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "meta/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Drona-Srivastava",
      "repo": "EduPlay",
      "private": false
    }
  }
}
